{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25 },

  "configurePresets": [
    {
      "name": "host",
      "displayName": "Host (Windows x64, VS 2022)",
      "description": "Multi-config Visual Studio build for the host platform. build/ serves both Debug and Release via --config.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build"
    },

    {
      "name": "host-tidy",
      "displayName": "Host Ninja (clang-tidy compile DB)",
      "description": "Ninja config that emits compile_commands.json for clang-tidy/clangd. NOT a shipping build — run from a VS x64 Developer prompt so cl.exe is on PATH. Output in build_tidy/.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_tidy",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_DISABLE_PRECOMPILE_HEADERS": "ON",
        "CMAKE_CXX_SCAN_FOR_MODULES": "OFF"
      }
    },

    {
      "name": "android-base",
      "hidden": true,
      "description": "Shared Android configuration — arm64-v8a, API 29, NDK r26d. Requires ANDROID_NDK_HOME.",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/android.toolchain.cmake"
    },
    {
      "name": "android-debug",
      "displayName": "Android arm64-v8a Debug",
      "inherits": "android-base",
      "binaryDir": "${sourceDir}/build_android/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "android-release",
      "displayName": "Android arm64-v8a Release",
      "inherits": "android-base",
      "binaryDir": "${sourceDir}/build_android/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "host-debug",
      "displayName": "Host Debug — kryga_editor",
      "configurePreset": "host",
      "configuration": "Debug",
      "targets": ["kryga_editor"]
    },
    {
      "name": "host-release",
      "displayName": "Host Release — kryga_editor",
      "configurePreset": "host",
      "configuration": "Release",
      "targets": ["kryga_editor"]
    },
    {
      "name": "host-all-debug",
      "displayName": "Host Debug — all targets",
      "configurePreset": "host",
      "configuration": "Debug"
    },

    {
      "name": "android-debug",
      "displayName": "Android Debug — kryga_game",
      "configurePreset": "android-debug",
      "targets": ["kryga_game"]
    },
    {
      "name": "android-release",
      "displayName": "Android Release — kryga_game",
      "configurePreset": "android-release",
      "targets": ["kryga_game"]
    }
  ],

  "workflowPresets": [
    {
      "name": "host-debug",
      "displayName": "Host Debug: configure + build",
      "steps": [
        { "type": "configure", "name": "host" },
        { "type": "build",     "name": "host-debug" }
      ]
    },
    {
      "name": "android-debug",
      "displayName": "Android Debug: configure + build",
      "steps": [
        { "type": "configure", "name": "android-debug" },
        { "type": "build",     "name": "android-debug" }
      ]
    },
    {
      "name": "android-release",
      "displayName": "Android Release: configure + build",
      "steps": [
        { "type": "configure", "name": "android-release" },
        { "type": "build",     "name": "android-release" }
      ]
    }
  ]
}
