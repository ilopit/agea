proto_id: directional_light
id: sun
layout: [-1, 0, 0]
components:
  - id: sun_root
    proto_id: game_object_component
  - id: sun_icon
    proto_id: mesh_component
    material: mt_billboard_directional_light
    mesh: plane_mesh
    layers:
      visible: true
      editor_only: true
      cast_shadows: false
      receive_light: false
      contribute_gi: false
      static_object: false
    position:
      x: 0
      y: 30
      z: 0
  - id: sun_lc
    proto_id: directional_light_component
    ambient:
      x: 0.2
      y: 0.2
      z: 0.22
    diffuse:
      x: 0.95
      y: 0.92
      z: 0.85
    specular:
      x: 0.3
      y: 0.3
      z: 0.3
    direction:
      x: -0.5
      y: -0.7
      z: -0.3
    selected: true
