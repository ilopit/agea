{
  "name": "kryga-editor",
  "displayName": "Kryga Editor",
  "description": "VS Code front-end for the Kryga engine.",
  "version": "0.0.2",
  "publisher": "kryga",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:kryga.project"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kryga.connect",
        "title": "Kryga: Connect to engine"
      },
      {
        "command": "kryga.disconnect",
        "title": "Kryga: Disconnect from engine"
      },
      {
        "command": "kryga.ping",
        "title": "Kryga: Ping engine"
      },
      {
        "command": "kryga.showOutput",
        "title": "Kryga: Show engine log output"
      },
      {
        "command": "kryga.scene.refresh",
        "title": "Kryga: Refresh scene tree",
        "icon": "$(refresh)"
      },
      {
        "command": "kryga.scene.filter",
        "title": "Kryga: Filter scene tree…",
        "icon": "$(search)"
      },
      {
        "command": "kryga.scene.clearFilter",
        "title": "Kryga: Clear scene filter",
        "icon": "$(close)"
      },
      {
        "command": "kryga.level.load",
        "title": "Kryga: Load level…"
      },
      {
        "command": "kryga.engine.toggleMode",
        "title": "Kryga: Toggle play/edit mode"
      },
      {
        "command": "kryga.engine.editMode",
        "title": "Kryga: Enter edit mode"
      },
      {
        "command": "kryga.engine.playMode",
        "title": "Kryga: Enter play mode"
      },
      {
        "command": "kryga.engine.start",
        "title": "Kryga: Start engine"
      },
      {
        "command": "kryga.engine.stop",
        "title": "Kryga: Stop engine"
      },
      {
        "command": "kryga.renderConfig",
        "title": "Kryga: Render Config",
        "icon": "$(gear)"
      },
      {
        "command": "kryga.bakeEditor",
        "title": "Kryga: Lightmap Baker"
      },
      {
        "command": "kryga.converter",
        "title": "Kryga: Asset Converter"
      },
      {
        "command": "kryga.scene.duplicate",
        "title": "Duplicate"
      },
      {
        "command": "kryga.scene.delete",
        "title": "Delete"
      },
      {
        "command": "kryga.scene.rename",
        "title": "Rename…"
      },
      {
        "command": "kryga.scene.create",
        "title": "Create Game Object…"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kryga",
          "title": "Kryga",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "kryga": [
        {
          "id": "kryga.scene",
          "name": "Scene"
        },
        {
          "id": "kryga.inspector",
          "name": "Inspector",
          "type": "webview"
        },
        {
          "id": "kryga.actionProgress",
          "name": "Actions",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kryga.scene.refresh",
          "when": "view == kryga.scene",
          "group": "navigation"
        },
        {
          "command": "kryga.scene.filter",
          "when": "view == kryga.scene",
          "group": "navigation"
        },
        {
          "command": "kryga.scene.create",
          "when": "view == kryga.scene"
        },
        {
          "command": "kryga.renderConfig",
          "when": "view == kryga.scene",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kryga.scene.duplicate",
          "when": "view == kryga.scene && viewItem == krygaObject",
          "group": "1_edit@1"
        },
        {
          "command": "kryga.scene.rename",
          "when": "view == kryga.scene && viewItem == krygaObject",
          "group": "1_edit@2"
        },
        {
          "command": "kryga.scene.delete",
          "when": "view == kryga.scene && viewItem == krygaObject",
          "group": "2_destructive@1"
        }
      ]
    },
    "configuration": {
      "title": "Kryga",
      "properties": {
        "kryga.hotReload.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reload shaders and Lua scripts on file save."
        },
        "kryga.hotReload.extensions": {
          "type": "array",
          "items": { "type": "string" },
          "default": [".vert", ".frag", ".comp", ".lua", ".glsl"],
          "description": "File extensions that trigger hot-reload on save."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-jsonrpc": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
