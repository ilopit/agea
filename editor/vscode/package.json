{
  "name": "kryga-editor",
  "displayName": "Kryga Editor",
  "description": "VS Code front-end for the Kryga engine (Phase 0 scaffold).",
  "version": "0.0.1",
  "publisher": "kryga",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kryga.openViewport",
        "title": "Kryga: Open Viewport"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
